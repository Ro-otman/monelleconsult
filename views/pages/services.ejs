<section class="page-hero section compact services-banner">
  <p class="eyebrow">Accompagnements de Monelle</p>
  <h1>Les domaines que Monelle éclaire avec attention.</h1>
  <p>Chaque guidance est portée par son écoute, son intuition et sa manière de lire les énergies autour de votre situation.</p>
</section>

<section class="section card-grid services-card-grid">
  <% services.forEach((service, index) => { %>
    <article class="service-card tall">
      <span class="card-icon"><i class="bx <%= service.icon %>" aria-hidden="true"></i></span>
      <h2><%= service.title %></h2>
      <p><%= service.text %></p>
      <% if (service.details) { %>
        <div class="service-details" id="service-page-details-<%= index %>" hidden>
          <% service.details.forEach((detail) => { %>
            <p><%= detail %></p>
          <% }) %>
          <strong>Consultation adaptée pour :</strong>
          <ul>
            <% service.suitedFor.forEach((item) => { %>
              <li><%= item %></li>
            <% }) %>
          </ul>
        </div>
        <button class="read-more-toggle" type="button" data-read-more aria-expanded="false" aria-controls="service-page-details-<%= index %>">
          Lire plus
        </button>
      <% } %>
      <a class="btn primary service-link service-cta" href="<%= primarySocial.href %>" target="_blank" rel="noopener noreferrer"><i class="bx <%= primarySocial.icon %>" aria-hidden="true"></i> Commencer la consultation</a>
    </article>
  <% }) %>
</section>

<section class="section quote-band services-quote-band">
  <h2>Vous n'avez pas besoin d'avoir toutes les réponses avant de parler à Monelle.</h2>
  <p>Une bonne guidance commence souvent par une sensation confuse. Monelle vous aide à mettre de l'ordre dans ce qui se présente.</p>
</section>

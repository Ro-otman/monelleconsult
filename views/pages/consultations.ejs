<section class="page-hero section compact consultations-banner">
  <p class="eyebrow">Réseaux de Monelle</p>
  <h1>Choisissez le réseau qui vous convient pour contacter Monelle.</h1>
  <p>Le site vous oriente simplement vers ses plateformes officielles. Envoyez votre question sur le canal où vous êtes le plus à l'aise.</p>
  <div class="hero-actions">
    <a class="btn primary" href="<%= primarySocial.href %>" target="_blank" rel="noopener noreferrer"><i class="bx <%= primarySocial.icon %>" aria-hidden="true"></i> Contacter sur WhatsApp</a>
    <a class="btn ghost" href="#reseaux"><i class="bx bx-share-alt" aria-hidden="true"></i> Voir les réseaux</a>
  </div>
</section>

<section class="section consultation-list" id="reseaux">
  <% socialLinks.forEach((social) => { %>
    <article class="consultation-format-card">
      <span class="card-icon"><i class="bx <%= social.icon %>" aria-hidden="true"></i></span>
      <h2><%= social.label %></h2>
      <p><%= social.text %></p>
      <a href="<%= social.href %>" target="_blank" rel="noopener noreferrer">Ouvrir <%= social.label %></a>
    </article>
  <% }) %>
</section>

<section class="section consultation-helper">
  <div class="section-heading narrow">
    <p class="eyebrow"><i class="bx bx-slider-alt" aria-hidden="true"></i> Choisir simplement</p>
    <h2>Chaque réseau mène directement vers Monelle.</h2>
  </div>
  <div class="consultation-choice-grid">
    <article>
      <strong>Pour aller vite</strong>
      <p>WhatsApp reste le lien le plus direct pour envoyer votre demande et recevoir les informations utiles.</p>
    </article>
    <article>
      <strong>Pour découvrir son univers</strong>
      <p>Instagram, TikTok et Snapchat permettent de suivre Monelle avant de lui écrire.</p>
    </article>
    <article>
      <strong>Pour rester informé</strong>
      <p>Facebook regroupe les actualités, les publications et les points de contact de Monelle.</p>
    </article>
  </div>
</section>

<section class="section final-cta">
  <div>
    <p class="eyebrow">Entrer en lien</p>
    <h2>Choisissez votre réseau préféré et envoyez votre demande à Monelle.</h2>
  </div>
  <a class="btn primary" href="<%= primarySocial.href %>" target="_blank" rel="noopener noreferrer"><i class="bx <%= primarySocial.icon %>" aria-hidden="true"></i> Contacter Monelle</a>
</section>
